{
  "name": "categorise_frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "generate-api-types": "openapi-generator-cli generate -i http://localhost:3050/openapi.json -g typescript-axios -o src/types/generated",
    "format": "prettier --write src/",
    "analyse-bundle": "vite-bundle-visualizer"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/vue-query": "^5.100.11",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "convert": "^7.0.0",
    "pinia": "^3.0.4",
    "uuid": "^13.0.2",
    "vite-bundle-analyzer": "^1.3.8",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.9.1",
    "@types/uuid": "^11.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "@vue/typescript-plugin": "^3.3.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  }
}
