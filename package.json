{
  "name": "categorise_frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "generate-api-types": "openapi-generator-cli generate -i http://localhost:3050/openapi.json -g typescript-axios -o src/types/generated",
    "format": "prettier --write src/",
    "analyse-bundle": "vite-bundle-visualizer"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/vue-query": "^5.101.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "convert": "^7.0.0",
    "pinia": "^3.0.4",
    "uuid": "^14.0.1",
    "vite-bundle-analyzer": "^1.3.8",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "wavesurfer.js": "^7.12.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@openapitools/openapi-generator-cli": "^2.39.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.0",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@vue/typescript-plugin": "^3.3.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
