{
  "name": "categorise_frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "generate-api-types": "openapi-generator-cli generate -i http://localhost:3050/openapi.json -g typescript-axios -o src/types/generated",
    "format": "prettier --write src/",
    "analyse-bundle": "vite-bundle-visualizer"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-query": "^5.92.9",
    "@vueuse/core": "^13.9.0",
    "axios": "^1.13.6",
    "convert": "^5.14.1",
    "pinia": "^3.0.4",
    "uuid": "^11.1.0",
    "vite-bundle-analyzer": "^1.3.6",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "wavesurfer.js": "^7.12.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.12.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "@vue/typescript-plugin": "^3.2.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  }
}
